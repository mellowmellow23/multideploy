# =============================================================================
# MultiDeploy — Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit your .env file to git
# =============================================================================

# Your deployer wallet private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Your deployer wallet address
DEPLOYER_ADDRESS=0xYourAddressHere

# RPC URLs — get free keys from Alchemy (https://alchemy.com)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY
OPTIMISM_SEPOLIA_RPC_URL=https://opt-sepolia.g.alchemy.com/v2/YOUR_KEY
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY

# Explorer API keys — get free keys from each explorer
ETHERSCAN_API_KEY=your_etherscan_key
BASESCAN_API_KEY=your_basescan_key
ARBISCAN_API_KEY=your_arbiscan_key
OPTIMISM_API_KEY=your_optimism_key
POLYGONSCAN_API_KEY=your_polygonscan_key
